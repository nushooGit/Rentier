#!/usr/bin/env bash
set -euo pipefail

BACKUP_DIR="/var/backups/rentier/postgresql"
DB_HOST="127.0.0.1"
DB_PORT="5432"
DB_NAME="DB_NAME"
DB_USER="DB_USER"
TIMESTAMP="$(date +%Y%m%d-%H%M%S)"
OUTPUT_FILE="$BACKUP_DIR/${DB_NAME}-${TIMESTAMP}.dump"

# Configure non-interactive authentication outside this script.
# Recommended: set PGPASSFILE to a PostgreSQL passfile owned by the backup user
# with 0600 permissions. Format: hostname:port:database:username:password
# Example placeholder:
# export PGPASSFILE="/home/BACKUP_USER/.pgpass"
# Peer authentication for a carefully configured local backup user is also valid.

mkdir -p "$BACKUP_DIR"
chmod 700 "$BACKUP_DIR"

pg_dump \
    --host="$DB_HOST" \
    --port="$DB_PORT" \
    --username="$DB_USER" \
    --format=custom \
    --file="$OUTPUT_FILE" \
    "$DB_NAME"

chmod 600 "$OUTPUT_FILE"
echo "Created PostgreSQL backup: $OUTPUT_FILE"
echo "Retention and off-server copy policies must be configured by the operator."
